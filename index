  const s = ST[id] || { got:false, rep:0 };
  const team = TEAMS.find(t => t.c === info?.team);
  const flag = team ? team.f : (info?.type==='fwc' ? '🌍' : info?.type==='coke' ? '🥤' : '⚽');

