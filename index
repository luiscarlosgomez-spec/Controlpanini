<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="theme-color" content="#060c1a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Panini 2026">
<title>🎴 Álbum Panini FIFA World Cup 2026™</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   PANINI 2026 — TEMA AZUL PREMIUM
   Paleta: Azul medianoche + Cyan eléctrico + Blanco
   Tipografía: Bebas Neue (display) + Outfit (body)
══════════════════════════════════════════ */
:root {
  /* Fondos azules — de más oscuro a más claro */
  --bg0:  #060c1a;   /* fondo base, casi negro azulado */
  --bg1:  #0a1628;   /* fondo principal */
  --bg2:  #0e1f38;   /* superficies */
  --bg3:  #132848;   /* superficies elevadas */
  --bg4:  #1a3360;   /* bordes activos / hover */

  /* Alias semánticos (mismos valores, nombres legibles en el código) */
  --pitch:   #060c1a;
  --pitch2:  #0a1628;
  --pitch3:  #0e1f38;
  --pitch4:  #132848;
  --surface: #0e1f38;
  --sur2:    #132848;
  --sur3:    #1a3360;

  /* Bordes */
  --bor:  rgba(100,160,255,0.10);
  --bor2: rgba(100,160,255,0.22);
  --bor3: rgba(100,160,255,0.40);

  /* Texto */
  --tx:  #e8f4ff;     /* blanco azulado — máximo contraste */
  --tx2: #7eb8e8;     /* azul claro — secundario */
  --tx3: #3a6090;     /* azul medio — hints */

  /* Acento principal: Cyan eléctrico */
  --cyan:    #00d4ff;
  --cyan2:   #40e8ff;
  --cyan-bg: rgba(0,212,255,.12);

  /* Acento secundario: Dorado FIFA */
  --gold:    #f5c842;
  --gold2:   #ffd966;
  --gold-bg: rgba(245,200,66,.12);

  /* Verde éxito (láminas obtenidas) */
  --grn:     #00e676;
  --grn2:    #69ff47;
  --grn-bg:  rgba(0,230,118,.10);

  /* Rojo error */
  --red:     #ff5252;
  --red-bg:  rgba(255,82,82,.10);

  /* Blanco puro */
  --white:   #ffffff;

  /* Coca-Cola */
  --coke:    #e8211a;
  --coke-bg: rgba(232,33,26,.12);

  /* Dimensiones */
  --r:   14px;
  --rs:  9px;
  --nav: 70px;

  /* Fonts */
  --ff-display: 'Bebas Neue', 'Impact', sans-serif;
  --ff-body:    'Outfit', 'Segoe UI', system-ui, sans-serif;
}

/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; -webkit-text-size-adjust: 100%; }
body {
  font-family: var(--ff-body);
  background: var(--bg0);
  color: var(--tx);
  overscroll-behavior: none;
  -webkit-tap-highlight-color: transparent;
}

/* ── FONDO: gradiente radial sutil + patrón diagonal muy tenue ── */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,100,200,.18) 0%, transparent 70%),
    radial-gradient(ellipse 60% 40% at 100% 100%, rgba(0,212,255,.07) 0%, transparent 60%);
}
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image: repeating-linear-gradient(
    -45deg,
    transparent, transparent 28px,
    rgba(100,160,255,.025) 28px, rgba(100,160,255,.025) 29px
  );
}

/* ── APP SHELL ── */
#app {
  position: relative; z-index: 1;
  display: flex; flex-direction: column;
  height: 100%; max-width: 520px;
  margin: 0 auto;
}

/* ── PAGES ── */
.page { display: none; flex-direction: column; height: 100%; overflow: hidden; }
.page.active { display: flex; }
.scroll {
  flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch;
  padding: 14px 16px calc(var(--nav) + 20px);
}
.scroll::-webkit-scrollbar { width: 3px; }
.scroll::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 9px; }

/* ── TOP BAR ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 18px 10px;
  background: linear-gradient(180deg, var(--bg0) 60%, transparent 100%);
  position: sticky; top: 0; z-index: 20; flex-shrink: 0;
}
.topbar-title {
  font-family: var(--ff-display);
  font-size: 26px; letter-spacing: 1.5px;
  color: var(--tx);
  text-shadow: 0 0 24px rgba(0,212,255,.35);
}
.topbar-title span { color: var(--cyan); }

/* ── BADGE ── */
.badge {
  background: var(--cyan); color: #001a2e;
  font-size: 11px; font-weight: 800;
  padding: 4px 11px; border-radius: 99px;
  letter-spacing: .3px;
}
.badge-gold { background: var(--gold); color: #1a1000; }
.badge-red  { background: var(--red);  color: #fff; }

/* ── BOTTOM NAV ── */
.nav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 520px;
  height: var(--nav);
  background: rgba(6,12,26,.96);
  border-top: 1px solid var(--bor2);
  display: flex; align-items: center; justify-content: space-around;
  padding: 0 6px;
  z-index: 100;
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}
.nb {
  display: flex; flex-direction: column; align-items: center; gap: 3px;
  flex: 1; padding: 6px 4px;
  cursor: pointer; background: none; border: none;
  color: var(--tx3);
  font-family: var(--ff-body);
  font-size: 9px; font-weight: 700;
  letter-spacing: .5px; text-transform: uppercase;
  transition: color .2s;
}
.nb .ni { font-size: 22px; transition: transform .2s; line-height: 1; }
.nb.active { color: var(--cyan); }
.nb.active .ni { transform: scale(1.15); }
.nb.center-btn .ni-wrap {
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, var(--cyan), #0090cc);
  display: flex; align-items: center; justify-content: center;
  margin-top: -20px;
  box-shadow: 0 4px 20px rgba(0,212,255,.55), 0 0 40px rgba(0,212,255,.20);
  font-size: 24px;
  transition: transform .2s, box-shadow .2s;
}
.nb.center-btn:active .ni-wrap { transform: scale(.94); }

/* ── CARDS ── */
.card {
  background: var(--surface);
  border: 1px solid var(--bor);
  border-radius: var(--r);
  padding: 16px;
  margin-bottom: 12px;
  position: relative; overflow: hidden;
}
.card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,212,255,.25), transparent);
}
.card-sm { border-radius: var(--rs); padding: 12px; }

/* ── HERO PROGRESS ── */
.hero-card {
  background: linear-gradient(135deg, #0e2040 0%, #0a1628 100%);
  border: 1px solid var(--bor2);
  border-radius: var(--r);
  padding: 22px 20px;
  margin-bottom: 14px;
  position: relative; overflow: hidden;
}
.hero-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--cyan), var(--gold), var(--cyan));
}
.hero-card::after {
  content: '⚽';
  position: absolute; right: -8px; bottom: -12px;
  font-size: 88px; opacity: .05;
  transform: rotate(-15deg);
  pointer-events: none;
}
.hero-pct {
  font-family: var(--ff-display);
  font-size: 72px; line-height: 1;
  color: var(--cyan);
  letter-spacing: -1px;
  text-shadow: 0 0 30px rgba(0,212,255,.45);
}
.hero-pct span { font-size: 32px; color: var(--tx2); }
.hero-sub { font-size: 13px; color: var(--tx2); margin-top: 4px; font-weight: 600; }

/* ── PROGRESS BAR ── */
.pb-wrap { margin-top: 14px; }
.pb-track {
  width: 100%; height: 8px;
  background: rgba(100,160,255,.08);
  border-radius: 99px; overflow: hidden;
}
.pb-fill {
  height: 100%; border-radius: 99px;
  background: linear-gradient(90deg, var(--cyan), var(--gold));
  transition: width .6s cubic-bezier(.34,1.56,.64,1);
  box-shadow: 0 0 10px rgba(0,212,255,.45);
}
.pb-labels {
  display: flex; justify-content: space-between;
  font-size: 11px; color: var(--tx3);
  margin-top: 6px; font-weight: 600;
}

/* ── STAT GRID ── */
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
.stat-card {
  background: var(--surface);
  border: 1px solid var(--bor);
  border-radius: var(--r);
  padding: 14px 12px; text-align: center;
  position: relative; overflow: hidden;
}
.stat-card .sv {
  font-family: var(--ff-display);
  font-size: 36px; line-height: 1;
  margin-bottom: 4px;
}
.stat-card .sl { font-size: 10px; color: var(--tx3); font-weight: 700; text-transform: uppercase; letter-spacing: .6px; }
.sv-gold  { color: var(--gold); }
.sv-red   { color: var(--red); }
.sv-lime  { color: var(--grn); }
.sv-white { color: var(--cyan); }

/* ── SECTION TITLE ── */
.sec-title {
  font-family: var(--ff-display);
  font-size: 17px; letter-spacing: 1px;
  color: var(--tx2);
  margin-bottom: 10px;
  display: flex; align-items: center; gap: 8px;
}
.sec-title::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--bor2), transparent);
}

/* ── TEAM CARD ── */
.team-card {
  background: var(--surface);
  border: 1px solid var(--bor);
  border-radius: var(--r);
  padding: 13px 15px;
  margin-bottom: 9px;
  cursor: pointer;
  transition: border-color .15s, background .15s;
  position: relative; overflow: hidden;
}
.team-card:hover { background: var(--sur2); border-color: var(--bor2); }
.team-card:active { opacity: .85; }
.team-card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.team-name { font-size: 14px; font-weight: 700; }
.team-flag { font-size: 22px; flex-shrink: 0; }
.team-pct { font-family: var(--ff-display); font-size: 22px; color: var(--cyan); }
.team-group {
  font-size: 9px; font-weight: 800; color: var(--tx3);
  background: rgba(0,212,255,.08); border-radius: 5px;
  padding: 2px 7px; text-transform: uppercase; letter-spacing: .5px;
}

/* ── CHIPS / FILTERS ── */
.chips {
  display: flex; gap: 7px; overflow-x: auto; padding-bottom: 4px;
  scrollbar-width: none; margin-bottom: 12px; flex-shrink: 0;
}
.chips::-webkit-scrollbar { display: none; }
.chip {
  white-space: nowrap; padding: 7px 15px;
  border-radius: 99px; font-size: 12px; font-weight: 700;
  cursor: pointer; border: 1px solid var(--bor);
  background: var(--surface); color: var(--tx2);
  transition: all .15s; flex-shrink: 0;
  font-family: var(--ff-body);
}
.chip:hover { border-color: var(--bor2); color: var(--tx); }
.chip.active { background: var(--cyan); color: #001a2e; border-color: var(--cyan); }

/* ── STICKER GRID ── */
.stk-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(56px, 1fr));
  gap: 5px; margin-bottom: 8px;
}
.stk {
  aspect-ratio: 3/4;
  border-radius: 8px;
  border: 2px solid var(--bor);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  cursor: pointer; position: relative;
  background: var(--surface);
  user-select: none; -webkit-user-select: none;
  transition: transform .12s, border-color .15s;
  overflow: hidden;
}
.stk:active { transform: scale(.88); }
.stk:hover { border-color: var(--bor2); }
/* Estados */
.stk.got {
  border-color: var(--grn);
  background: rgba(0,230,118,.08);
}
.stk.dup {
  border-color: var(--gold);
  background: rgba(245,200,66,.08);
}
.stk.mis { opacity: .35; }
/* FOIL */
.stk.foil { border-color: rgba(245,200,66,.45); background: rgba(245,200,66,.06); }
.stk.foil.got { border-color: var(--gold); background: rgba(245,200,66,.14); }
/* Coca-Cola */
.stk.coke { border-color: rgba(232,33,26,.45); background: rgba(232,33,26,.06); }
.stk.coke.got { border-color: var(--coke); background: rgba(232,33,26,.12); }

.stk .stk-team { font-size: 8px; font-weight: 800; color: var(--tx3); line-height: 1; }
.stk .stk-num {
  font-family: var(--ff-display);
  font-size: 18px; line-height: 1.1;
  color: var(--tx2);
}
.stk.got  .stk-num { color: var(--grn); }
.stk.dup  .stk-num { color: var(--gold); }
.stk.foil .stk-num { color: var(--gold); }
.stk.coke .stk-num { color: var(--coke); }
.stk.coke.got .stk-num { color: var(--coke); }

.stk .rep-badge {
  position: absolute; top: 2px; right: 3px;
  font-size: 8px; font-weight: 800; color: var(--gold);
  line-height: 1;
}
.stk .foil-dot {
  position: absolute; top: 2px; left: 3px;
  font-size: 7px; line-height: 1; opacity: .8;
}
/* Foto grupal */
.stk.photo { border-color: rgba(0,212,255,.3); }
.stk.photo .stk-num { font-size: 9px; font-weight: 800; color: var(--cyan); text-align: center; line-height: 1.2; }

/* ── SECTION HEADER (album) ── */
.sec-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px; padding: 0 2px;
}
.sec-header-left { display: flex; align-items: center; gap: 8px; }
.sec-flag { font-size: 20px; line-height: 1; }
.sec-name { font-size: 14px; font-weight: 700; }
.sec-progress { font-size: 11px; color: var(--tx3); font-weight: 600; }
.sec-group {
  font-size: 9px; font-weight: 800;
  color: var(--cyan); background: rgba(0,212,255,.10);
  border-radius: 4px; padding: 2px 6px;
  border: 1px solid rgba(0,212,255,.20);
}

/* ── BUTTONS ── */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 7px;
  padding: 13px 22px; border-radius: var(--rs);
  border: none; cursor: pointer;
  font-family: var(--ff-body);
  font-size: 14px; font-weight: 700;
  transition: all .15s; letter-spacing: .2px;
}
.btn:active { transform: scale(.96); }
.btn-gold  { background: linear-gradient(135deg, var(--gold), #c8900a); color: #1a1000; box-shadow: 0 4px 16px rgba(245,200,66,.35); }
.btn-ghost { background: var(--sur2); color: var(--tx); border: 1px solid var(--bor2); }
.btn-lime  { background: var(--grn-bg); color: var(--grn); border: 1px solid rgba(0,230,118,.3); }
.btn-red   { background: var(--red-bg); color: var(--red); border: 1px solid rgba(255,82,82,.3); }
.btn-coke  { background: var(--coke-bg); color: var(--coke); border: 1px solid rgba(232,33,26,.3); }
.btn-cyan  { background: linear-gradient(135deg, var(--cyan), #0090cc); color: #001a2e; box-shadow: 0 4px 16px rgba(0,212,255,.35); }
.full { width: 100%; }
.btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; }

/* ── SEARCH BAR ── */
.search-wrap { position: relative; margin-bottom: 12px; flex-shrink: 0; }
.search-wrap input {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--bor);
  border-radius: 11px;
  padding: 11px 14px 11px 42px;
  color: var(--tx);
  font-size: 14px;
  font-family: var(--ff-body);
}
.search-wrap input:focus { outline: none; border-color: rgba(0,212,255,.5); }
.search-wrap input::placeholder { color: var(--tx3); }
.search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 16px; }

/* ── MODAL ── */
.mo {
  position: fixed; inset: 0;
  background: rgba(0,8,20,.80);
  z-index: 200; display: none; align-items: flex-end; justify-content: center;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
.mo.open { display: flex; }
.md {
  background: var(--bg2);
  width: 100%; max-width: 520px;
  border-radius: var(--r) var(--r) 0 0;
  padding: 22px 18px 44px;
  max-height: 82vh; overflow-y: auto;
  border-top: 1px solid var(--bor2);
  animation: slideUp .28s cubic-bezier(.34,1.56,.64,1);
}
@keyframes slideUp { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.md-handle { width: 40px; height: 4px; background: var(--bor3); border-radius: 99px; margin: 0 auto 20px; }
.md-title { font-family: var(--ff-display); font-size: 22px; letter-spacing: 1px; margin-bottom: 16px; color: var(--cyan); }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: calc(var(--nav) + 16px); left: 50%; transform: translateX(-50%);
  background: var(--sur3); color: var(--tx);
  border: 1px solid var(--bor2);
  padding: 11px 20px; border-radius: 99px;
  font-size: 13px; font-weight: 700;
  z-index: 300; white-space: nowrap;
  box-shadow: 0 8px 32px rgba(0,0,0,.5);
  display: none;
  animation: tIn .25s ease, tOut .25s ease 2.2s forwards;
}
@keyframes tIn { from { opacity:0; transform:translate(-50%,14px); } to { opacity:1; transform:translate(-50%,0); } }
@keyframes tOut { to { opacity:0; transform:translate(-50%,14px); } }

/* ── REP LIST ── */
.rep-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px;
  background: var(--surface);
  border: 1px solid var(--bor);
  border-radius: var(--rs);
  margin-bottom: 7px;
}
.rep-code { font-family: var(--ff-display); font-size: 16px; letter-spacing: .5px; }
.rep-sub { font-size: 11px; color: var(--tx3); margin-top: 2px; }
.rep-cnt {
  background: var(--gold-bg); color: var(--gold);
  border: 1px solid rgba(245,200,66,.3);
  font-size: 12px; font-weight: 800;
  padding: 4px 12px; border-radius: 99px;
}

/* ── EXCHANGE ── */
.exc-card {
  background: var(--surface); border: 1px solid var(--bor);
  border-radius: var(--r); padding: 20px; text-align: center; margin-bottom: 12px;
}
.qr-canvas { border-radius: var(--rs); display: block; margin: 0 auto; image-rendering: pixelated; }
.match-ok {
  background: var(--grn-bg); border: 1px solid rgba(0,230,118,.3);
  border-radius: var(--rs); padding: 11px 14px;
  font-size: 13px; font-weight: 700; color: var(--grn);
  margin-bottom: 10px; display: flex; align-items: center; gap: 8px;
}

/* ── INPUTS ── */
input, textarea {
  background: var(--surface); border: 1px solid var(--bor);
  border-radius: var(--rs); padding: 11px 14px;
  color: var(--tx); font-size: 14px;
  font-family: var(--ff-body);
  outline: none; transition: border-color .2s;
}
input:focus, textarea:focus { border-color: rgba(0,212,255,.5); }
input::placeholder, textarea::placeholder { color: var(--tx3); }

/* ── DIVIDER ── */
.divider { border: none; border-top: 1px solid var(--bor); margin: 14px 0; }

/* ── MISC ── */
.c-gold { color: var(--gold); }
.c-lime { color: var(--grn); }
.c-red  { color: var(--red); }
.c-coke { color: var(--coke); }
.c-tx2  { color: var(--tx2); }
.c-tx3  { color: var(--tx3); }
.fw9    { font-weight: 900; }
.fs11   { font-size: 11px; }
.fs12   { font-size: 12px; }
.fs13   { font-size: 13px; }
.mt8    { margin-top: 8px; }
.mb8    { margin-bottom: 8px; }
.mb12   { margin-bottom: 12px; }
.mb16   { margin-bottom: 16px; }
.row    { display: flex; align-items: center; gap: 9px; }
.empty-state { text-align: center; padding: 40px 20px; color: var(--tx3); }
.empty-state .ei { font-size: 48px; margin-bottom: 12px; }
.empty-state p { font-size: 14px; }

/* ── LOADING ── */
#loading {
  position: fixed; inset: 0; z-index: 1000;
  background: var(--bg0);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 20px;
}
.load-logo {
  font-family: var(--ff-display);
  font-size: 52px; letter-spacing: 4px;
  color: var(--cyan);
  text-shadow: 0 0 40px rgba(0,212,255,.55);
  text-align: center;
}
.load-sub { font-size: 13px; color: var(--tx3); letter-spacing: 2px; text-transform: uppercase; }
.load-bar-wrap { width: 180px; height: 4px; background: var(--bg3); border-radius: 99px; overflow: hidden; }
.load-bar-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--cyan), var(--gold)); border-radius: 99px; transition: width .35s; }

/* ── RESPONSIVE PC ── */
@media (min-width: 520px) {
  .nav { border-radius: var(--r) var(--r) 0 0; }
