  const teamData = TEAMS.map(t => {
    const got = Array.from({length:20}, (_,i) => `${t.c} ${i+1}`).filter(id => ST[id]?.got).length;
    return { ...t, got, pct: Math.round((got/20)*100) };
  }).sort((a,b) => b.got - a.got).slice(0, 8);

  document.getElementById('ini-teams').innerHTML = teamData.map(t => `
    <div class="team-card" onclick="goAlbumSection('${t.c}')">
      <div class="team-card-head">
        <div class="row">
          <span class="team-flag">${t.f}</span>
          <div>
            <div class="team-name">${t.n}</div>
            <span class="team-group">Grupo ${t.g}</span>
          </div>
        </div>
        <div class="team-pct">${t.pct}%</div>
      </div>
      <div class="pb-track"><div class="pb-fill" style="width:${t.pct}%"></div></div>
      <div class="pb-labels"><span>${t.got}/20 láminas</span><span>${20-t.got} faltantes</span></div>
