  document.getElementById('ms-info').textContent = info?.name || '';

  document.getElementById('ms-stats').innerHTML = `
    <div style="background:var(--pitch3);border-radius:var(--rs);padding:12px;text-align:center">
      <div style="font-family:var(--ff-display);font-size:28px;color:${s.got?'var(--lime)':'var(--red)'};line-height:1">${s.got?'✅':'❌'}</div>
      <div class="fs11 c-tx3" style="margin-top:3px;text-transform:uppercase;font-weight:700">${s.got?'Obtenida':'Faltante'}</div>
    </div>
    <div style="background:var(--pitch3);border-radius:var(--rs);padding:12px;text-align:center">
      <div style="font-family:var(--ff-display);font-size:28px;color:var(--gold);line-height:1">${s.rep||0}</div>
      <div class="fs11 c-tx3" style="margin-top:3px;text-transform:uppercase;font-weight:700">Repetidas</div>
    </div>`;

  const isCoke = info?.type === 'coke';
  if (s.got) {
    document.getElementById('ms-actions').innerHTML = `
      <button class="btn ${isCoke?'btn-coke':'btn-ghost'} full" onclick="doAddRep('${id}')">🔄 Agregar repetida</button>
      ${s.rep > 0 ? `<button class="btn btn-ghost full" onclick="doRemRep('${id}')">➖ Quitar repetida</button>` : ''}
      <button class="btn btn-red full" onclick="doRemStk('${id}')">🗑 Quitar del álbum</button>
      <button class="btn btn-ghost full" onclick="closeM('m-stk')">Cerrar</button>`;
  } else {
    document.getElementById('ms-actions').innerHTML = `
      <button class="btn btn-lime full" onclick="doAddStk('${id}',1)">✅ Marcar como obtenida</button>
      ${isCoke ? '<p class="fs11 c-coke" style="text-align:center;margin-top:4px">🥤 Solo en botellas Coca-Cola</p>' : ''}
      <button class="btn btn-ghost full" onclick="closeM('m-stk')">Cerrar</button>`;
  }
  openM('m-stk');
}

// ─── STICKER OPERATIONS ──────────────────────────────────────

async function doAddStk(id, qty = 1) {
  const ex = ST[id] || { id, got:false, rep:0 };
  if (ex.got) { ex.rep = (ex.rep||0) + (qty-1); }
  else { ex.got = true; ex.rep = qty-1; ex.date = new Date().toISOString(); }
  ST[id] = ex;
  await dbPut('stk', ex);
  toast('✅ ' + id + ' obtenida');
  doRefresh();
}

async function doAddRep(id) {
  const s = ST[id] || { id, got:true, rep:0 };
  s.rep = (s.rep||0) + 1;
  ST[id] = s;
  await dbPut('stk', s);
  toast('🔄 Repetida de ' + id);
  closeM('m-stk'); doRefresh();
}

async function doRemRep(id) {
  const s = ST[id]; if (!s) return;
  s.rep = Math.max(0, (s.rep||1) - 1);
  await dbPut('stk', s);
  toast('✅ Repetida eliminada');
  closeM('m-stk'); doRefresh();
}

async function doRemStk(id) {
  delete ST[id];
  await dbDel('stk', id);
  toast('❌ ' + id + ' eliminada');
  closeM('m-stk'); doRefresh();
}

function doRefresh() {
  refreshStats();
  const ap = document.querySelector('.page.active');
  if (!ap) return;
  const pid = ap.id.replace('page-','');
  if (pid === 'inicio') renderInicio();
  if (pid === 'album')  renderAlbum();
  if (pid === 'rep')    renderRep();
}

// ─── MANUAL ADD ──────────────────────────────────────────────

function openManual() {
  document.getElementById('man-code').value = '';
  document.getElementById('man-qty').value = '1';
  openM('m-man');
}

async function doManualAdd() {
  const raw = document.getElementById('man-code').value.trim().toUpperCase();
  const qty = parseInt(document.getElementById('man-qty').value) || 1;
  if (!raw) { toast('⚠️ Ingresa un código'); return; }

  // Normalizar: quitar espacio extra
  const norm = raw.replace(/\s+/, ' ').trim();

  // Buscar directamente
  if (IDX[norm]) {
    await doAddStk(norm, qty);
    closeM('m-man'); return;
  }
  // Intentar formato sin espacio: COL5 → COL 5
  const m = norm.match(/^([A-Z]{2,4})\s*(\d{1,3})$/);
  if (m) {
    const id = m[1] + ' ' + parseInt(m[2]);
    if (IDX[id]) { await doAddStk(id, qty); closeM('m-man'); return; }
  }
  toast('⚠️ Código no existe en el álbum');
}

// ─── SCANNER ─────────────────────────────────────────────────

async function startCam() {
  // Limpieza completa antes de abrir cámara
  resetScanZone();
  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      video:{ facingMode:'environment', width:{ideal:1280}, height:{ideal:720} }
    });
    cameraStream = stream;
    const vid = document.getElementById('scan-video');
    vid.srcObject = stream;
    vid.style.display = 'block';
    document.getElementById('scan-ph').style.display = 'none';
    document.getElementById('scan-zone').style.background = '#000';
    const btn = document.getElementById('btn-cam');
    btn.innerHTML = '📸 Capturar foto';
    btn.onclick = doCapture;
  } catch(e) {
    toast('⚠️ Sin acceso a cámara. Usa Galería.');
    document.getElementById('file-input').click();
  }
}

function doCapture() {
  const vid = document.getElementById('scan-video');
  const cv  = document.getElementById('scan-canvas');
  cv.width = vid.videoWidth; cv.height = vid.videoHeight;
  cv.getContext('2d').drawImage(vid, 0, 0);
  stopCam();
  // Mostrar preview
  const prev = document.getElementById('scan-prev');
  prev.src = cv.toDataURL('image/jpeg', .92);
  prev.style.display = 'block';
  processImg(cv);
}

function stopCam() {
  if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }
  const vid = document.getElementById('scan-video');
  vid.pause();
  vid.srcObject = null;
  vid.style.display = 'none';
  const btn = document.getElementById('btn-cam');
  btn.innerHTML = '📷 Cámara';
  btn.onclick = startCam;
}

// Resetea la zona visual al estado inicial (sin imagen anterior)
function resetScanZone() {
  stopCam();
  const prev = document.getElementById('scan-prev');
  prev.src = ''; prev.style.display = 'none';
  document.getElementById('scan-ph').style.display = 'flex';
  document.getElementById('scan-zone').style.background = 'var(--pitch3)';
  document.getElementById('scan-proc').style.display = 'none';
  document.getElementById('scan-results').style.display = 'none';
  document.getElementById('scan-list').innerHTML = '';
  document.getElementById('scan-btns-normal').style.display = 'block';
  document.getElementById('scan-btns-confirm').style.display = 'none';
}

function onFile(e) {
  const file = e.target.files[0]; if (!file) return;
  resetScanZone();
  const reader = new FileReader();
  reader.onload = ev => {
    const img = new Image();
    img.onload = () => {
      const cv = document.getElementById('scan-canvas');
      cv.width = img.width; cv.height = img.height;
      cv.getContext('2d').drawImage(img, 0, 0);
      const prev = document.getElementById('scan-prev');
      prev.src = ev.target.result;
      prev.style.display = 'block';
      document.getElementById('scan-ph').style.display = 'none';
      processImg(cv);
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}

// Preprocesa la imagen para mejorar el OCR:
// aumenta contraste, convierte a escala de grises y aplica umbral
function preprocessForOCR(srcCanvas) {
  const dst = document.getElementById('ocr-canvas');
  const w = srcCanvas.width, h = srcCanvas.height;
  // Escalar si es muy grande (OCR funciona mejor en ~1000px ancho)
  const scale = Math.min(1, 1200 / Math.max(w, h));
  dst.width  = Math.round(w * scale);
  dst.height = Math.round(h * scale);
  const ctx = dst.getContext('2d');
  // Escalar imagen
  ctx.drawImage(srcCanvas, 0, 0, dst.width, dst.height);
  // Obtener pixels
  const img = ctx.getImageData(0, 0, dst.width, dst.height);
  const d = img.data;
  for (let i = 0; i < d.length; i += 4) {
    // Convertir a gris con pesos perceptivos
    const gray = 0.299*d[i] + 0.587*d[i+1] + 0.114*d[i+2];
    // Aumentar contraste (factor 1.8, punto medio 128)
    const c = Math.min(255, Math.max(0, (gray - 128) * 1.8 + 128));
    // Umbral adaptativo simple: si > 140 → blanco, si no → negro
    // (el texto del reverso de las láminas Panini es oscuro sobre fondo claro)
    const bin = c > 140 ? 255 : 0;
    d[i] = d[i+1] = d[i+2] = bin;
    d[i+3] = 255;
  }
  ctx.putImageData(img, 0, 0);
  return dst;
}

async function processImg(cv) {
  document.getElementById('scan-ph').style.display = 'none';
  document.getElementById('scan-proc').style.display = 'flex';
  document.getElementById('scan-results').style.display = 'none';
  document.getElementById('scan-btns-normal').style.display = 'none';
  document.getElementById('scan-btns-confirm').style.display = 'none';
  const bar = document.getElementById('ocr-bar'); bar.style.width = '8%';

  try {
    // Preprocesar imagen
    const processed = preprocessForOCR(cv);
    bar.style.width = '20%';

    const wk = await Tesseract.createWorker('eng', 1, {
      logger: m => {
        if (m.status === 'recognizing text')
          bar.style.width = Math.round(m.progress * 65 + 20) + '%';
      }
    });
    await wk.setParameters({
      tessedit_char_whitelist: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 ',
      tessedit_pageseg_mode:   '6', // Bloque uniforme de texto
      tessedit_ocr_engine_mode:'1', // LSTM
    });

    // Intentar primero con imagen preprocesada
    let result = await wk.recognize(processed);
    let codes  = extractCodes(result.data.text);

    // Si no encontró nada, intentar con imagen original
    if (codes.length === 0) {
      result = await wk.recognize(cv);
      codes  = extractCodes(result.data.text);
    }

    await wk.terminate();
    bar.style.width = '100%';

    document.getElementById('scan-proc').style.display = 'none';
    showScanResults(codes);

  } catch(e) {
    console.error(e);
    document.getElementById('scan-proc').style.display = 'none';
    toast('⚠️ Error al procesar. Agrega los códigos manualmente.');
    showScanResults([]);
  }
}

function extractCodes(text) {
  const found = new Set();
  // Normalizar: quitar saltos de línea, tabs, múltiples espacios
  const clean = text.replace(/[\r\n\t]+/g, ' ').replace(/\s+/g, ' ');
  // Patrón principal: 2-4 letras + espacio opcional + 1-3 dígitos
  const re = /\b([A-Z]{2,4})\s*(\d{1,3})\b/g;
  let m;
  while ((m = re.exec(clean)) !== null) {
    const id = m[1] + ' ' + parseInt(m[2]);
    if (IDX[id]) found.add(id);
  }
  return [...found];
}

function showScanResults(codes) {
  document.getElementById('scan-results').style.display = 'block';
  document.getElementById('scan-btns-confirm').style.display = 'block';
  document.getElementById('scan-btns-normal').style.display = 'none';
  document.getElementById('scan-cnt').textContent = '(' + codes.length + ')';
  const list = document.getElementById('scan-list');
  if (!codes.length) {
    list.innerHTML = '<p class="fs12 c-tx3" style="padding:10px 0;text-align:center">No se detectaron códigos.<br>Usa <strong style="color:var(--gold)">+ Manual</strong> para agregar.</p>';
    return;
  }
  list.innerHTML = codes.map((c, i) => `
    <div class="row" id="sr-${i}" style="padding:8px;background:var(--surface);border:1px solid var(--bor);border-radius:var(--rs);margin-bottom:6px">
      <div style="width:44px;height:44px;border-radius:7px;background:linear-gradient(135deg,var(--gold),#c8900a);color:#000;font-weight:800;font-size:9px;display:flex;align-items:center;justify-content:center;text-align:center;flex-shrink:0;line-height:1.2">${c}</div>
      <input type="text" value="${c}" style="flex:1;font-family:monospace;font-size:13px" oninput="this.value=this.value.toUpperCase()">
      <button style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer;padding:4px" onclick="document.getElementById('sr-${i}').remove();updateScanCnt()">×</button>
    </div>`).join('');
}

function addScanRow() {
  const i = Date.now();
  const div = document.createElement('div');
  div.className = 'row'; div.id = 'sr-' + i;
  div.style.cssText = 'padding:8px;background:var(--surface);border:1px solid var(--bor);border-radius:var(--rs);margin-bottom:6px';
  div.innerHTML = `
    <div id="srb-${i}" style="width:44px;height:44px;border-radius:7px;background:var(--pitch4);color:var(--tx3);font-weight:800;font-size:9px;display:flex;align-items:center;justify-content:center;text-align:center;flex-shrink:0">?</div>
    <input type="text" placeholder="COL 5" style="flex:1;font-family:monospace;font-size:13px"
      oninput="this.value=this.value.toUpperCase();document.getElementById('srb-${i}').textContent=this.value||'?'">
    <button style="background:none;border:none;color:var(--red);font-size:18px;cursor:pointer;padding:4px" onclick="this.parentElement.remove();updateScanCnt()">×</button>`;
  document.getElementById('scan-list').appendChild(div);
  div.querySelector('input').focus();
  updateScanCnt();
  // Mostrar botones de confirmación si no están
  document.getElementById('scan-btns-confirm').style.display = 'block';
  document.getElementById('scan-btns-normal').style.display = 'none';
}

function updateScanCnt() {
  const n = document.querySelectorAll('#scan-list .row').length;
  document.getElementById('scan-cnt').textContent = '(' + n + ')';
}

async function confirmScan() {
  const inputs = document.querySelectorAll('#scan-list input');
  const codes = [];
  inputs.forEach(inp => {
    const v = inp.value.trim().toUpperCase();
    const m = v.match(/^([A-Z]{2,4})\s*(\d{1,3})$/);
    if (m) { const id = m[1]+' '+parseInt(m[2]); if (IDX[id]) codes.push(id); }
  });
  if (!codes.length) { toast('⚠️ Sin láminas válidas'); return; }
  for (const c of codes) await doAddStk(c, 1);
  toast('✅ ' + codes.length + ' láminas agregadas');
  clearScan();
}

function clearScan() {
  resetScanZone();
}

// ─── REPETIDAS ───────────────────────────────────────────────

function renderRep() {
  const body = document.getElementById('rep-body'); if (!body) return;
  const reps = Object.values(ST)
    .filter(s => s.got && s.rep > 0)
    .sort((a,b) => a.id.localeCompare(b.id));
  if (!reps.length) {
    body.innerHTML = '<div class="empty-state"><div class="ei">🔄</div><p>No tienes láminas repetidas aún</p></div>';
    return;
  }
  body.innerHTML = reps.map(s => {
    const info = IDX[s.id];
    const team = TEAMS.find(t => t.c === info?.team);
    const flag = team ? team.f : (info?.type==='fwc'?'🌍':'🥤');
    const sub  = team ? team.n : (info?.name || '');
    return `<div class="rep-item">
      <div>
        <div class="rep-code">${flag} ${s.id}</div>
        <div class="rep-sub">${sub}</div>
      </div>
      <div class="row">
        <span class="rep-cnt">×${s.rep}</span>
        <button class="btn btn-ghost" style="padding:7px 11px;font-size:12px" onclick="openStk('${s.id}')">✏️</button>
      </div>
    </div>`;
  }).join('');
}

// ─── INTERCAMBIOS ────────────────────────────────────────────

function saveUname() {
  userName = document.getElementById('uname-in').value;
  dbPut('cfg', { k:'uname', v:userName });
}

function getSharePayload() {
  const reps   = Object.values(ST).filter(s => s.got && s.rep > 0).map(s => ({ id:s.id, qty:s.rep }));
  const missing = Object.keys(IDX).filter(id => !ST[id]?.got);
  return { user: userName||'Coleccionista', reps, missing, pct: stats().pct, date: new Date().toISOString() };
}

function genQR() {
  const d = getSharePayload();
  const compact = { u:d.user, r:d.reps.slice(0,50), m:d.missing.slice(0,100) };
  const json = JSON.stringify(compact);
  document.getElementById('qr-box').style.display = 'block';
  document.getElementById('qr-name').textContent = '⚽ ' + d.user;
  document.getElementById('qr-info').textContent = d.reps.length + ' repetidas · ' + d.missing.length + ' faltantes · ' + d.pct + '%';
  const cv = document.getElementById('qr-cv');
  cv.width = 200; cv.height = 200;
  if (typeof QRCode !== 'undefined') {
    cv.getContext('2d').clearRect(0,0,200,200);
    try {
      new QRCode(cv, { text:json, width:200, height:200, colorDark:'#00d4ff', colorLight:'#0a1628', correctLevel:QRCode.CorrectLevel.M });
    } catch(e) { qrFallback(cv, d.user); }
  } else { qrFallback(cv, d.user); }
  cv.scrollIntoView({ behavior:'smooth' });
}

function qrFallback(cv, name) {
  const ctx = cv.getContext('2d');
  ctx.fillStyle = '#0a1628'; ctx.fillRect(0,0,200,200);
  ctx.fillStyle = '#00d4ff'; ctx.font = 'bold 14px sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('⚽ ' + name, 100, 88);
  ctx.fillStyle = '#4a7055'; ctx.font = '11px sans-serif';
  ctx.fillText('Usa "Compartir" para', 100, 112);
  ctx.fillText('enviar tu colección', 100, 130);
}

async function shareData() {
  const d = getSharePayload();
  const json = JSON.stringify(d, null, 2);
  if (navigator.share) {
    try { await navigator.share({ title:'Mi Álbum Panini 2026 · '+d.user, text:json }); return; }
    catch(e) {}
  }
  try { await navigator.clipboard.writeText(json); toast('📋 Copiado al portapapeles'); }
  catch(e) { toast('⚠️ No se pudo copiar'); }
}

async function copyRepList() {
  const reps = Object.values(ST).filter(s => s.got && s.rep > 0).sort((a,b) => a.id.localeCompare(b.id));
  if (!reps.length) { toast('Sin repetidas para copiar'); return; }
  const txt = `⚽ Repetidas de ${userName||'Álbum Panini 2026'}\n\n` +
              reps.map(s => `${s.id} ×${s.rep}`).join('\n') +
              `\n\nTotal: ${reps.length} tipos`;
  try { await navigator.clipboard.writeText(txt); toast('📋 Lista copiada'); }
  catch(e) { toast('⚠️ Error al copiar'); }
}

function compareCollections() {
  const raw = document.getElementById('imp-area').value.trim();
  if (!raw) { toast('⚠️ Pega la lista de tu amigo'); return; }
  let friend;
  try {
    friend = JSON.parse(raw);
    if (!friend.reps && !friend.missing) throw new Error('');
  } catch(e) {
    const codes = extractCodes(raw.toUpperCase());
    friend = { user:'Amigo', reps:codes.map(id => ({id, qty:1})), missing:[] };
  }
  showMatchResults(friend);
}

function showMatchResults(fr) {
  const myReps    = Object.values(ST).filter(s => s.got && s.rep > 0);
  const myMissing = Object.keys(IDX).filter(id => !ST[id]?.got);
  const frRepIds  = (fr.reps||[]).map(r => typeof r==='string' ? r : r.id);
  const frMissIds = (fr.missing||[]).map(r => typeof r==='string' ? r : r.id);
  const iGive     = myReps.filter(s => frMissIds.includes(s.id));
  const theyGive  = frRepIds.filter(id => myMissing.includes(id));
  const el = document.getElementById('match-body');
  if (!iGive.length && !theyGive.length) {
    el.innerHTML = `<div class="empty-state" style="padding:20px"><div class="ei">🤷</div><p>Sin coincidencias con ${fr.user||'tu amigo'}</p></div>`;
    return;
  }
  const tag = (id, color, bg, border) =>
    `<span style="background:${bg};color:${color};border:1px solid ${border};padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;display:inline-block;margin:2px">${id}</span>`;
  el.innerHTML = `
    <div style="font-family:var(--ff-display);font-size:16px;letter-spacing:.5px;color:var(--tx2);margin-bottom:10px">RESULTADOS CON ${(fr.user||'AMIGO').toUpperCase()}</div>
    ${iGive.length ? `
      <div class="match-ok">✅ Tienes <strong style="color:var(--white)">${iGive.length}</strong> que ${fr.user||'tu amigo'} necesita</div>
      <div class="card card-sm mb12">
        <div class="fs11 c-tx3 fw9 mb8">YO PUEDO DAR</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px">${iGive.map(s=>tag(s.id,'var(--grn)','var(--grn-bg)','rgba(0,230,118,.3)')).join('')}</div>
      </div>` : ''}
    ${theyGive.length ? `
      <div class="match-ok" style="background:var(--gold-bg);border-color:rgba(245,200,66,.3);color:var(--gold)">🎯 ${fr.user||'Tu amigo'} tiene <strong style="color:var(--white)">${theyGive.length}</strong> que tú necesitas</div>
      <div class="card card-sm mb12">
        <div class="fs11 c-tx3 fw9 mb8">ELLOS PUEDEN DAR</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px">${theyGive.map(id=>tag(id,'var(--gold)','var(--gold-bg)','rgba(245,200,66,.3)')).join('')}</div>
      </div>` : ''}`;
}

// ─── MODALS ──────────────────────────────────────────────────

const openM  = id => document.getElementById(id).classList.add('open');
const closeM = id => document.getElementById(id).classList.remove('open');
document.querySelectorAll('.mo').forEach(el =>
  el.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('open'); })
);

// ─── TOAST ───────────────────────────────────────────────────

let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.style.display = 'block';
  el.style.animation = 'none'; el.offsetHeight;
  el.style.animation = 'tIn .25s ease, tOut .25s ease 2.2s forwards';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.style.display = 'none', 2600);
}

// ─── PWA ─────────────────────────────────────────────────────

function injectManifest() {
  const m = {
    name:'Álbum Panini FIFA 2026',
    short_name:'Panini 2026',
    start_url:'.', display:'standalone',
    background_color:'#060c1a', theme_color:'#00d4ff',
    orientation:'portrait-primary',
    icons:[{
      src:'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192"><rect width="192" height="192" rx="40" fill="%23060c1a"/><text y="130" x="96" font-size="110" text-anchor="middle">⚽</text></svg>',
      sizes:'192x192', type:'image/svg+xml'
    }]
  };
  const link = document.createElement('link');
  link.rel = 'manifest';
  link.href = URL.createObjectURL(new Blob([JSON.stringify(m)], { type:'application/json' }));
  document.head.appendChild(link);
}

function registerSW() {
  if (!('serviceWorker' in navigator)) return;
  const code = `
const C='panini2026-v5';
self.addEventListener('install',e=>{
  e.waitUntil(caches.open(C).then(c=>c.addAll([location.href])));
  self.skipWaiting();
});
self.addEventListener('activate',e=>{
  e.waitUntil(caches.keys().then(ks=>Promise.all(ks.filter(k=>k!==C).map(k=>caches.delete(k)))));
  self.clients.claim();
});
self.addEventListener('fetch',e=>{
  e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request).catch(()=>caches.match(location.href))));
});`.trim();
  navigator.serviceWorker.register(
    URL.createObjectURL(new Blob([code], { type:'application/javascript' }))
  ).catch(() => {});
}

// ─── INIT ────────────────────────────────────────────────────

async function init() {
  const bar = document.getElementById('load-bar');
  const msg = document.getElementById('load-msg');

  msg.textContent = 'Abriendo base de datos...'; bar.style.width = '20%';
  await dbInit();

  msg.textContent = 'Cargando tu colección...'; bar.style.width = '55%';
  await loadAll();

  msg.textContent = 'Preparando álbum...'; bar.style.width = '80%';
  refreshStats();
  renderInicio();
  injectManifest();
  registerSW();

  bar.style.width = '100%';
  setTimeout(() => {
    const ls = document.getElementById('loading');
    ls.style.transition = 'opacity .35s';
    ls.style.opacity = '0';
    setTimeout(() => ls.remove(), 380);
  }, 400);
}

init();
</script>
