<script>
// ════════════════════════════════════════════════════════════════
//  PANINI FIFA WORLD CUP 2026™ — VERSIÓN LATINOAMERICANA
//  Estructura real álbum físico impreso:
//    • 980 láminas base: FWC (20) + 48 equipos × 20
//    • 14 Coca-Cola: página especial dentro del álbum
//    Total: 994 posiciones en el álbum
//
//  Extra Stickers (~80): NO van en el álbum, se rastrean por separado
// ════════════════════════════════════════════════════════════════

// ─── DATOS REALES DEL ÁLBUM ──────────────────────────────────

// Sección FWC: 20 láminas (00 + FWC 1-19), todas FOIL
const FWC = [
  { id:'FWC 00', name:'Logo Panini',           foil:true },
  { id:'FWC 1',  name:'Emblema Oficial',        foil:true },
  { id:'FWC 2',  name:'Emblema Oficial',         foil:true },
  { id:'FWC 3',  name:'Mascotas Oficiales',      foil:true },
  { id:'FWC 4',  name:'Slogan Oficial',          foil:true },
  { id:'FWC 5',  name:'Balón Oficial',           foil:true },
  { id:'FWC 6',  name:'Canadá — País Anfitrión', foil:true },
  { id:'FWC 7',  name:'México — País Anfitrión', foil:true },
  { id:'FWC 8',  name:'USA — País Anfitrión',    foil:true },
  { id:'FWC 9',  name:'Italia 1934',             foil:true },
  { id:'FWC 10', name:'Uruguay 1950',            foil:true },
  { id:'FWC 11', name:'Alemania Occ. 1954',      foil:true },
  { id:'FWC 12', name:'Brasil 1962',             foil:true },
  { id:'FWC 13', name:'Alemania Occ. 1974',      foil:true },
  { id:'FWC 14', name:'Argentina 1986',          foil:true },
  { id:'FWC 15', name:'Brasil 1994',             foil:true },
  { id:'FWC 16', name:'Brasil 2002',             foil:true },
  { id:'FWC 17', name:'Italia 2006',             foil:true },
  { id:'FWC 18', name:'Alemania 2014',           foil:true },
  { id:'FWC 19', name:'Argentina 2022',          foil:true },
];

// 48 equipos clasificados con siglas FIFA oficiales y grupos
const TEAMS = [
  { c:'MEX', n:'México',             f:'🇲🇽', g:'A' },
  { c:'RSA', n:'Sudáfrica',          f:'🇿🇦', g:'A' },
  { c:'KOR', n:'Corea del Sur',      f:'🇰🇷', g:'A' },
  { c:'CZE', n:'Chequia',            f:'🇨🇿', g:'A' },
  { c:'ESP', n:'España',             f:'🇪🇸', g:'B' },
  { c:'MAR', n:'Marruecos',          f:'🇲🇦', g:'B' },
  { c:'BRA', n:'Brasil',             f:'🇧🇷', g:'B' },
  { c:'JPN', n:'Japón',              f:'🇯🇵', g:'B' },
  { c:'GER', n:'Alemania',           f:'🇩🇪', g:'C' },
  { c:'USA', n:'Estados Unidos',     f:'🇺🇸', g:'C' },
  { c:'SRB', n:'Serbia',             f:'🇷🇸', g:'C' },
  { c:'NZL', n:'Nueva Zelanda',      f:'🇳🇿', g:'C' },
  { c:'FRA', n:'Francia',            f:'🇫🇷', g:'D' },
  { c:'AUS', n:'Australia',          f:'🇦🇺', g:'D' },
  { c:'TUR', n:'Turquía',            f:'🇹🇷', g:'D' },
  { c:'CHI', n:'Chile',              f:'🇨🇱', g:'D' },
  { c:'CAN', n:'Canadá',             f:'🇨🇦', g:'E' },
  { c:'BIH', n:'Bosnia y Herz.',     f:'🇧🇦', g:'E' },
  { c:'QAT', n:'Qatar',              f:'🇶🇦', g:'E' },
  { c:'SUI', n:'Suiza',              f:'🇨🇭', g:'E' },
  { c:'ENG', n:'Inglaterra',         f:'🏴󠁧󠁢󠁥󠁮󠁧󠁿', g:'F' },
  { c:'NED', n:'Países Bajos',       f:'🇳🇱', g:'F' },
  { c:'IRN', n:'Irán',               f:'🇮🇷', g:'F' },
  { c:'CPV', n:'Cabo Verde',         f:'🇨🇻', g:'F' },
  { c:'POR', n:'Portugal',           f:'🇵🇹', g:'G' },
  { c:'COL', n:'Colombia',           f:'🇨🇴', g:'G' },
  { c:'UZB', n:'Uzbekistán',         f:'🇺🇿', g:'G' },
  { c:'COD', n:'Congo DR',           f:'🇨🇩', g:'G' },
  { c:'ARG', n:'Argentina',          f:'🇦🇷', g:'H' },
  { c:'NOR', n:'Noruega',            f:'🇳🇴', g:'H' },
  { c:'SWE', n:'Suecia',             f:'🇸🇪', g:'H' },
  { c:'IRQ', n:'Irak',               f:'🇮🇶', g:'H' },
  { c:'CRO', n:'Croacia',            f:'🇭🇷', g:'I' },
  { c:'ECU', n:'Ecuador',            f:'🇪🇨', g:'I' },
  { c:'ALG', n:'Argelia',            f:'🇩🇿', g:'I' },
  { c:'EGY', n:'Egipto',             f:'🇪🇬', g:'I' },
  { c:'BEL', n:'Bélgica',            f:'🇧🇪', g:'J' },
  { c:'AUT', n:'Austria',            f:'🇦🇹', g:'J' },
  { c:'SCO', n:'Escocia',            f:'🏴󠁧󠁢󠁳󠁣󠁴󠁿', g:'J' },
  { c:'PAN', n:'Panamá',             f:'🇵🇦', g:'J' },
  { c:'NGA', n:'Nigeria',            f:'🇳🇬', g:'K' },
  { c:'GHA', n:'Ghana',              f:'🇬🇭', g:'K' },
  { c:'SEN', n:'Senegal',            f:'🇸🇳', g:'K' },
  { c:'HTI', n:'Haití',              f:'🇭🇹', g:'K' },
  { c:'URU', n:'Uruguay',            f:'🇺🇾', g:'L' },
  { c:'KSA', n:'Arabia Saudita',     f:'🇸🇦', g:'L' },
  { c:'HUN', n:'Hungría',            f:'🇭🇺', g:'L' },
  { c:'CUW', n:'Curazao',            f:'🇨🇼', g:'L' },
];

// Coca-Cola: 14 láminas (versión latinoamericana) — página especial en el álbum
const COKE = [
  { id:'CC 1',  name:'Lamine Yamal',       team:'España'       },
  { id:'CC 2',  name:'Joshua Kimmich',     team:'Alemania'     },
  { id:'CC 3',  name:'Harry Kane',         team:'Inglaterra'   },
  { id:'CC 4',  name:'Santiago Giménez',   team:'México'       },
  { id:'CC 5',  name:'Antonee Robinson',   team:'USA'          },
  { id:'CC 6',  name:'Jefferson Lerma',    team:'Colombia'     },
  { id:'CC 7',  name:'Edson Álvarez',      team:'México'       },
  { id:'CC 8',  name:'Virgil van Dijk',    team:'Países Bajos' },
  { id:'CC 9',  name:'Alphonso Davies',    team:'Canadá'       },
  { id:'CC 10', name:'Weston McKennie',    team:'USA'          },
  { id:'CC 11', name:'Lautaro Martínez',   team:'Argentina'    },
  { id:'CC 12', name:'Gabriel Magalhães',  team:'Brasil'       },
  { id:'CC 13', name:'Luis Díaz',          team:'Colombia'     },
  { id:'CC 14', name:'James Rodríguez',    team:'Colombia'     },
];

// ─── ÍNDICE MAESTRO ──────────────────────────────────────────

function buildIndex() {
  const idx = {};
  // FWC
  FWC.forEach(s => { idx[s.id] = { ...s, type:'fwc', section:'FWC' }; });
  // Equipos
  TEAMS.forEach(t => {
    for (let i = 1; i <= 20; i++) {
      const id = `${t.c} ${i}`;
      idx[id] = {
        id, type:'team', section:t.c,
        team:t.c, teamName:t.n, flag:t.f, group:t.g,
        num:i,
        foil: i === 1,           // #1 = Escudo FOIL
        photo: i === 13,         // #13 = Foto grupal
        name: i === 1 ? `Escudo ${t.n}` : i === 13 ? `Foto Grupal ${t.n}` : `Jugador ${i}`,
      };
    }
  });
  // Coca-Cola
  COKE.forEach(s => { idx[s.id] = { ...s, type:'coke', section:'CC', foil:false }; });
  return idx;
}

const IDX = buildIndex();
const TOTAL_BASE = 980;   // FWC(20) + equipos(48×20=960)
const TOTAL_CC   = 14;
const TOTAL_ALB  = TOTAL_BASE + TOTAL_CC; // 994 posiciones en el álbum

// ─── STATE & DB ──────────────────────────────────────────────

let db = null;
let ST = {};      // { [id]: { id, got:bool, rep:int, date? } }
let userName = '';
let albumFilter = 'all';
let cameraStream = null;

async function dbInit() {
  return new Promise((res, rej) => {
    const r = indexedDB.open('Panini2026v5', 1);
    r.onerror = () => rej(r.error);
    r.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('stk')) d.createObjectStore('stk', { keyPath:'id' });
      if (!d.objectStoreNames.contains('cfg')) d.createObjectStore('cfg', { keyPath:'k' });
    };
    r.onsuccess = () => { db = r.result; res(); };
  });
}
const dbGet  = (st,k)   => new Promise(r => { const q=db.transaction(st,'readonly').objectStore(st).get(k); q.onsuccess=()=>r(q.result); q.onerror=()=>r(null); });
const dbPut  = (st,v)   => new Promise(r => { const tx=db.transaction(st,'readwrite'); tx.objectStore(st).put(v); tx.oncomplete=r; });
const dbDel  = (st,k)   => new Promise(r => { const tx=db.transaction(st,'readwrite'); tx.objectStore(st).delete(k); tx.oncomplete=r; });
const dbAll  = (st)     => new Promise(r => { const q=db.transaction(st,'readonly').objectStore(st).getAll(); q.onsuccess=()=>r(q.result||[]); q.onerror=()=>r([]); });

async function loadAll() {
  const rows = await dbAll('stk');
  ST = {};
  rows.forEach(r => ST[r.id] = r);
  const u = await dbGet('cfg','uname');
  if (u) { userName = u.v; const el=document.getElementById('uname-in'); if(el) el.value=userName; }
}

// ─── STATS ───────────────────────────────────────────────────

function stats() {
  let got=0, rep=0;
  Object.values(ST).forEach(s => {
    if (s.got) got++;
    if (s.rep > 0) rep += s.rep;
  });
  const pct = Math.round((Math.min(got, TOTAL_BASE) / TOTAL_BASE) * 100);
  const fwcGot  = FWC.filter(s => ST[s.id]?.got).length;
  const ccGot   = COKE.filter(s => ST[s.id]?.got).length;
  return { got, rep, mis: TOTAL_BASE - Math.min(got, TOTAL_BASE), pct, fwcGot, ccGot };
}

function refreshStats() {
  const s = stats();
  // Hero
  document.getElementById('h-pct').innerHTML = s.pct + '<span>%</span>';
  document.getElementById('h-sub').textContent = `${s.got} de ${TOTAL_BASE} láminas completadas`;
  document.getElementById('h-fill').style.width = s.pct + '%';
  document.getElementById('h-got-lbl').textContent = `${s.got} obtenidas`;
  document.getElementById('h-mis-lbl').textContent = `${s.mis} faltantes`;
  const ring = document.getElementById('ring');
  if (ring) { const c=188.5; ring.style.strokeDashoffset = c - (s.pct/100)*c; }
  // Stat cards
  document.getElementById('s-got').textContent = s.got;
  document.getElementById('s-mis').textContent = s.mis;
  document.getElementById('s-rep').textContent = s.rep;
  // Album badge
  const ap = document.getElementById('al-pct-label'); if(ap) ap.textContent = s.pct+'%';
  // Rep badge
  const rb = document.getElementById('rep-badge'); if(rb) rb.textContent = s.rep;
  // Sections
  document.getElementById('s-fwc-n').textContent = `${s.fwcGot}/20`;
  document.getElementById('s-fwc-bar').style.width = Math.round((s.fwcGot/20)*100)+'%';
  document.getElementById('s-cc-n').textContent = `${s.ccGot}/14`;
  document.getElementById('s-cc-bar').style.width = Math.round((s.ccGot/14)*100)+'%';
}

// ─── NAVIGATION ──────────────────────────────────────────────

function goPage(pid, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + pid).classList.add('active');
  if (btn) btn.classList.add('active');
  if (pid === 'inicio')  renderInicio();
  if (pid === 'album')   renderAlbum();
  if (pid === 'rep')     renderRep();
  if (pid === 'scan')    resetScanZone();
}

function goAlbumFilter(f) {
  goPage('album', document.querySelectorAll('.nb')[1]);
  setTimeout(() => {
    albumFilter = f;
    document.querySelectorAll('#al-chips .chip').forEach(c => c.classList.remove('active'));
    const map = { all:0, got:1, mis:2, dup:3, fwc:4, coke:5 };
    const chips = document.querySelectorAll('#al-chips .chip');
    if (chips[map[f]]) chips[map[f]].classList.add('active');
    renderAlbum();
  }, 50);
}

// ─── INICIO ──────────────────────────────────────────────────

