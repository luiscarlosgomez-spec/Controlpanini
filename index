}

function goAlbumSection(teamCode) {
  goPage('album', document.querySelectorAll('.nb')[1]);
  setTimeout(() => {
    albumFilter = 'all';
    document.querySelectorAll('#al-chips .chip').forEach((c,i) => c.classList.toggle('active', i===0));
    renderAlbum();
    setTimeout(() => {
      const el = document.getElementById('sec-' + teamCode);
      if (el) el.scrollIntoView({ behavior:'smooth', block:'start' });
    }, 100);
  }, 60);
}

// ─── ÁLBUM ───────────────────────────────────────────────────

function setFilter(f, btn) {
  albumFilter = f;
  document.querySelectorAll('#al-chips .chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  renderAlbum();
}

function applyStateFilter(ids) {
  if (albumFilter === 'got') return ids.filter(id => ST[id]?.got && !(ST[id]?.rep > 0));
  if (albumFilter === 'mis') return ids.filter(id => !ST[id]?.got);
  if (albumFilter === 'dup') return ids.filter(id => ST[id]?.rep > 0);
  return ids;
}

function renderAlbum() {
  const body = document.getElementById('album-body');
  if (!body) return;
  const q = (document.getElementById('al-search')?.value || '').toUpperCase().trim();
  let html = '';

  // ── FWC ──
  const showFWC = albumFilter === 'all' || albumFilter === 'fwc' || albumFilter === 'got' || albumFilter === 'mis' || albumFilter === 'dup';
  if (showFWC) {
    let ids = applyStateFilter(FWC.map(s => s.id));
    if (q) ids = ids.filter(id => id.replace(' ','').includes(q.replace(' ','')) || IDX[id]?.name?.toUpperCase().includes(q));
    if (ids.length) {
      const got = FWC.filter(s => ST[s.id]?.got).length;
      html += buildSection('sec-FWC', '🌍', 'FWC — Intro e Historia', `${got}/20`, ids, 'FWC', null);
    }
  }

  // ── EQUIPOS ──
  if (albumFilter !== 'fwc' && albumFilter !== 'coke') {
    const grupos = [...new Set(TEAMS.map(t => t.g))];
    grupos.forEach(g => {
      TEAMS.filter(t => t.g === g).forEach(t => {
        let ids = applyStateFilter(Array.from({length:20}, (_,i) => `${t.c} ${i+1}`));
        if (q) ids = ids.filter(id => {
          const num = id.split(' ')[1];
          return id.replace(' ','').includes(q.replace(' ','')) ||
                 t.n.toUpperCase().includes(q) || t.c.includes(q) || num === q;
        });
        if (!ids.length) return;
        const got = Array.from({length:20}, (_,i) => `${t.c} ${i+1}`).filter(id => ST[id]?.got).length;
        html += buildSection(`sec-${t.c}`, t.f, `${t.n}`, `${got}/20`, ids, t.c, t.g);
      });
    });
  }

  // ── COCA-COLA ──
  if (albumFilter === 'all' || albumFilter === 'coke') {
    let ids = applyStateFilter(COKE.map(s => s.id));
    if (q) ids = ids.filter(id => id.includes(q) || IDX[id]?.name?.toUpperCase().includes(q) || IDX[id]?.team?.toUpperCase().includes(q));
    if (ids.length) {
      const got = COKE.filter(s => ST[s.id]?.got).length;
      html += buildSection('sec-CC', '🥤', 'Coca-Cola™ — Exclusivas', `${got}/14`, ids, 'CC', null);
    }
  }

  body.innerHTML = html || '<div class="empty-state"><div class="ei">🔍</div><p>Sin resultados para tu búsqueda</p></div>';
}

function buildSection(sid, flag, name, progress, ids, sectionCode, group) {
  const cells = ids.map(id => buildCell(id)).join('');
  const groupBadge = group ? `<span class="sec-group">Grupo ${group}</span>` : '';
  return `<div id="${sid}" style="margin-bottom:18px">
    <div class="sec-header">
      <div class="sec-header-left">
        <span class="sec-flag">${flag}</span>
        <div>
          <span class="sec-name">${name}</span>
          ${groupBadge}
        </div>
      </div>
      <span class="sec-progress">${progress}</span>
    </div>
    <div class="stk-grid">${cells}</div>
  </div>`;
}

function buildCell(id) {
  const info = IDX[id];
  if (!info) return '';
  const s = ST[id];
  const got = s?.got || false;
  const rep = s?.rep || 0;

  let cls = 'stk';
  if (info.foil) cls += ' foil';
  if (info.type === 'coke') cls += ' coke';
  if (got && rep > 0) cls += ' dup';
  else if (got) cls += ' got';
  else cls += ' mis';
  if (info.photo && !info.foil) cls += ' photo';

  const parts = id.split(' ');
  const teamCode = parts[0];
  const numDisp  = parts.slice(1).join(' ');

  const repHtml  = rep > 0 ? `<span class="rep-badge">×${rep+1}</span>` : '';
  const foilDot  = info.foil ? `<span class="foil-dot">✨</span>` : '';

  let numLabel;
  if (info.photo) {
    numLabel = `<span class="stk-num" style="font-size:8px;font-weight:800;line-height:1.2;text-align:center">FOTO</span>`;
  } else {
    numLabel = `<span class="stk-num">${numDisp}</span>`;
  }

  return `<div class="${cls}" onclick="openStk('${id}')" title="${info.name || id}">
    ${foilDot}${repHtml}
    <span class="stk-team">${teamCode}</span>
    ${numLabel}
  </div>`;
}

